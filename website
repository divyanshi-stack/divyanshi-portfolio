        <div class="art-pub">${a.pub}</div>
        <span class="art-tag ${a.tagClass}">${a.tag}</span>
        <div class="art-title">${a.title}</div>
        <div class="art-footer">
          <span class="art-date">${a.date}</span>
          <span class="art-arrow">Read →</span>
        </div>
      </div>
    </div>`).join('');
}

function openM(i){
  const a=arts[i];
  document.getElementById('modalThumbSVG').innerHTML=a.svg;
  document.getElementById('mPub').textContent=a.pub;
  const t=document.getElementById('mTag');t.textContent=a.tag;t.className=`modal-ttag ${a.tagClass}`;
  document.getElementById('mTitle').textContent=a.title;
  document.getElementById('mDesc').textContent=a.desc;
  document.getElementById('mMeta').innerHTML=a.meta.map(m=>`<span>${m}</span>`).join('');
  document.getElementById('mActions').innerHTML=`<a href="${a.url}" target="_blank" class="btn-grad" style="font-size:0.85rem;padding:0.72rem 1.6rem;">Read Full Article →</a>`;
  document.getElementById('overlay').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeMB(){document.getElementById('overlay').classList.remove('open');document.body.style.overflow='';}
function closeModal(e){if(e.target===document.getElementById('overlay'))closeMB();}
