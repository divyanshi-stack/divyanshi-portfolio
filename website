.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:100px 2rem 4rem;text-align:center;position:relative;overflow:hidden;background:#000;}
.hero-glow{position:absolute;inset:0;pointer-events:none;}
.glow-ring{position:absolute;border-radius:50%;border:1px solid rgba(192,132,252,0.15);}
.glow-ring:nth-child(1){width:600px;height:600px;top:50%;left:50%;transform:translate(-50%,-50%) rotateX(70deg);box-shadow:0 0 80px rgba(192,132,252,0.2) inset;animation:spin3d 20s linear infinite;}
.glow-ring:nth-child(2){width:800px;height:800px;top:50%;left:50%;transform:translate(-50%,-50%) rotateX(70deg) rotateZ(30deg);box-shadow:0 0 60px rgba(244,114,182,0.15) inset;animation:spin3d 28s linear infinite reverse;}
