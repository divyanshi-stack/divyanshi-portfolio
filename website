function renderArts(){
  document.getElementById('artGrid').innerHTML = arts.map((a,i)=>`
    <div class="art-card" onclick="openM(${i})">
      <svg class="art-thumb" viewBox="0 0 580 220" xmlns="http://www.w3.org/2000/svg">${a.svg}</svg>
