.stats{display:grid;grid-template-columns:repeat(4,1fr);max-width:900px;margin:0 auto;padding:4rem 2rem;gap:0;}
.stat{text-align:center;padding:2rem 1rem;border-right:1px solid rgba(255,255,255,0.07);}
.stat:last-child{border-right:none;}
.stat-num{font-size:2.8rem;font-weight:700;letter-spacing:-0.04em;background:linear-gradient(135deg,#c084fc,#f472b6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;display:block;}
.stat-label{font-size:0.75rem;color:rgba(255,255,255,0.4);letter-spacing:0.08em;text-transform:uppercase;margin-top:0.3rem;}
.full-bleed{width:100%;padding:7rem 2rem;display:flex;flex-direction:column;align-items:center;text-align:center;}
.full-bleed.dark{background:#000;}
.full-bleed.grey{background:#0a0a0a;}
.sec-eyebrow{font-size:0.72rem;letter-spacing:0.2em;text-transform:uppercase;color:#c084fc;font-weight:600;margin-bottom:0.6rem;}
.sec-title{font-size:clamp(2rem,4vw,3.2rem);font-weight:700;letter-spacing:-0.04em;line-height:1.1;max-width:700px;margin-bottom:1rem;}
.sec-sub{font-size:0.95rem;color:rgba(255,255,255,0.5);max-width:520px;line-height:1.85;margin-bottom:3.5rem;}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;max-width:1000px;width:100%;text-align:left;}
.about-text p{font-size:0.95rem;color:rgba(255,255,255,0.55);line-height:2;margin-bottom:1rem;}
.about-text strong{color:#f5f5f7;}
.grad-word{background:linear-gradient(135deg,#c084fc,#f472b6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-weight:600;}
.skills-col{display:flex;flex-direction:column;gap:1.4rem;}
.sg-title{font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-bottom:0.5rem;font-weight:600;}
.stags{display:flex;flex-wrap:wrap;gap:0.4rem;}
.stag{padding:0.26rem 0.8rem;border-radius:999px;font-size:0.74rem;border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);background:rgba(255,255,255,0.04);transition:all 0.2s;cursor:default;}
.stag:hover{border-color:rgba(192,132,252,0.5);color:#c084fc;}
.pub-strip{display:flex;gap:1.5rem;justify-content:center;flex-wrap:wrap;max-width:900px;}
.pub-card{flex:1;min-width:240px;max-width:280px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);border-radius:20px;padding:2rem 1.6rem;text-align:left;transition:transform 0.3s,border-color 0.3s,box-shadow 0.3s;position:relative;overflow:hidden;}
.pub-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(192,132,252,0.06),transparent);opacity:0;transition:opacity 0.3s;}
.pub-card:hover{transform:translateY(-6px) scale(1.02);border-color:rgba(192,132,252,0.3);box-shadow:0 24px 60px rgba(124,58,237,0.18);}
.pub-card:hover::before{opacity:1;}
.pub-icon{font-size:2rem;margin-bottom:1rem;}
.pub-name{font-size:1rem;font-weight:700;color:#f5f5f7;margin-bottom:0.4rem;}
.pub-desc{font-size:0.8rem;color:rgba(255,255,255,0.45);line-height:1.7;margin-bottom:1.2rem;}
.pub-link{font-size:0.78rem;color:#c084fc;text-decoration:none;font-weight:600;transition:color 0.2s;}
.pub-link:hover{color:#f472b6;}
.pub-count{position:absolute;top:1.2rem;right:1.4rem;font-size:0.68rem;color:rgba(255,255,255,0.25);letter-spacing:0.08em;}
.articles-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.2rem;max-width:1060px;width:100%;}
.art-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:18px;overflow:hidden;cursor:pointer;transition:transform 0.28s,border-color 0.28s,box-shadow 0.28s;display:flex;flex-direction:column;}
.art-card:hover{transform:translateY(-6px);border-color:rgba(192,132,252,0.35);box-shadow:0 20px 60px rgba(0,0,0,0.6);}
.art-thumb{width:100%;height:170px;display:block;flex-shrink:0;}
.art-body{padding:1.2rem 1.3rem;flex:1;display:flex;flex-direction:column;text-align:left;}
.art-pub{font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:0.3rem;font-weight:600;}
.art-tag{display:inline-block;font-size:0.65rem;letter-spacing:0.07em;text-transform:uppercase;color:#fff;padding:0.18rem 0.6rem;border-radius:999px;margin-bottom:0.7rem;font-weight:600;}
.tag-purple{background:linear-gradient(90deg,#7c3aed,#9333ea);}
.tag-pink{background:linear-gradient(90deg,#db2777,#e879a8);}
.tag-blue{background:linear-gradient(90deg,#0ea5e9,#38bdf8);}
.tag-amber{background:linear-gradient(90deg,#d97706,#f59e0b);}
.tag-green{background:linear-gradient(90deg,#059669,#10b981);}
.art-title{font-size:0.9rem;font-weight:600;line-height:1.5;flex:1;color:#f5f5f7;}
.art-footer{display:flex;justify-content:space-between;align-items:center;margin-top:0.9rem;padding-top:0.8rem;border-top:1px solid rgba(255,255,255,0.07);}
.art-date{font-size:0.72rem;color:rgba(255,255,255,0.3);}
.art-arrow{font-size:0.75rem;color:#c084fc;opacity:0;transition:opacity 0.2s;}
.art-card:hover .art-arrow{opacity:1;}
.see-more-row{display:flex;gap:0.8rem;flex-wrap:wrap;justify-content:center;margin-top:2.5rem;}
.contact-scene{max-width:800px;width:100%;position:relative;}
.contact-card{background:linear-gradient(160deg,#1a0533 0%,#0d0d1a 100%);border:1px solid rgba(192,132,252,0.2);border-radius:30px;padding:4.5rem 3rem;text-align:center;position:relative;overflow:hidden;box-shadow:0 40px 100px rgba(124,58,237,0.25);}
.contact-card::before{content:'';position:absolute;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(192,132,252,0.12),transparent 65%);top:-120px;left:50%;transform:translateX(-50%);}
.contact-card h2{font-size:clamp(2rem,4vw,3rem);font-weight:700;letter-spacing:-0.04em;margin-bottom:1rem;position:relative;}
.contact-card p{font-size:0.95rem;color:rgba(255,255,255,0.5);max-width:440px;margin:0 auto 0.5rem;position:relative;}
.contact-email{display:inline-block;font-size:1rem;font-weight:500;color:rgba(255,255,255,0.7);margin:1rem 0 2rem;position:relative;}
.btn-big{display:inline-block;padding:1rem 2.5rem;border-radius:999px;font-size:1rem;font-weight:700;background:linear-gradient(135deg,#7c3aed,#db2777);color:#fff;text-decoration:none;border:none;cursor:pointer;transition:transform 0.2s,box-shadow 0.2s;position:relative;margin-bottom:2.5rem;}
.btn-big:hover{transform:translateY(-3px);box-shadow:0 16px 50px rgba(124,58,237,0.5);}
.c-links{display:flex;gap:0.7rem;justify-content:center;flex-wrap:wrap;position:relative;}
.c-link{padding:0.5rem 1.1rem;border-radius:999px;font-size:0.8rem;border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.65);text-decoration:none;background:rgba(255,255,255,0.04);transition:all 0.2s;}
.c-link:hover{border-color:rgba(192,132,252,0.5);color:#c084fc;transform:translateY(-2px);}
.c-location{font-size:0.78rem;color:rgba(255,255,255,0.3);margin-top:1.4rem;position:relative;}
footer{background:#000;border-top:1px solid rgba(255,255,255,0.08);padding:2rem 3rem;display:flex;justify-content:space-between;align-items:center;font-size:0.78rem;color:rgba(255,255,255,0.3);}
.float-hire{position:fixed;bottom:2rem;right:2rem;z-index:800;padding:0.72rem 1.4rem;border-radius:999px;font-size:0.82rem;font-weight:700;background:linear-gradient(135deg,#7c3aed,#db2777);color:#fff;cursor:pointer;box-shadow:0 8px 30px rgba(124,58,237,0.45);animation:floatb 3s ease-in-out infinite;border:none;}
@keyframes floatb{0%,100%{transform:translateY(0);}50%{transform:translateY(-5px);}}
.overlay{position:fixed;inset:0;background:rgba(0,0,0,0.85);backdrop-filter:blur(12px);z-index:1000;display:flex;align-items:center;justify-content:center;padding:1.5rem;opacity:0;pointer-events:none;transition:opacity 0.25s;}
.overlay.open{opacity:1;pointer-events:all;}
.modal{background:#1a1a1f;border:1px solid rgba(255,255,255,0.1);border-radius:22px;max-width:580px;width:100%;max-height:88vh;overflow-y:auto;transform:translateY(20px) scale(0.97);transition:transform 0.25s;position:relative;}
.overlay.open .modal{transform:none;}
.modal-art-thumb{width:100%;height:220px;display:block;border-radius:18px 18px 0 0;}
.modal-body{padding:1.8rem 2rem 2.2rem;}
.modal-pub{font-size:0.68rem;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-bottom:0.4rem;}
.modal-ttag{display:inline-block;font-size:0.7rem;letter-spacing:0.08em;text-transform:uppercase;color:#fff;padding:0.22rem 0.7rem;border-radius:999px;margin-bottom:1rem;font-weight:600;}
.modal-h{font-size:1.5rem;font-weight:700;letter-spacing:-0.03em;margin-bottom:1rem;line-height:1.3;}
.modal-desc{font-size:0.9rem;color:rgba(255,255,255,0.55);line-height:1.9;margin-bottom:1.5rem;}
.modal-tags{display:flex;gap:0.4rem;flex-wrap:wrap;margin-bottom:1.8rem;}
.modal-tags span{padding:0.22rem 0.7rem;border-radius:999px;font-size:0.72rem;border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.45);}
.modal-close{position:absolute;top:1rem;right:1rem;width:34px;height:34px;border-radius:50%;background:rgba(255,255,255,0.1);border:none;color:rgba(255,255,255,0.6);font-size:1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;z-index:10;}
.modal-close:hover{background:rgba(192,132,252,0.3);color:#fff;}
@media(max-width:700px){nav{padding:0 1.2rem;}.nav-links{display:none;}.stats{grid-template-columns:repeat(2,1fr);}.about-grid{grid-template-columns:1fr;gap:2rem;}footer{flex-direction:column;gap:0.5rem;}.contact-card{padding:3rem 1.5rem;}.float-hire{bottom:1.2rem;right:1.2rem;}}
</style>
</head>
