nav{position:fixed;top:0;width:100%;z-index:900;background:rgba(0,0,0,0.72);backdrop-filter:saturate(180%) blur(20px);border-bottom:1px solid rgba(255,255,255,0.08);display:flex;justify-content:space-between;align-items:center;padding:0 3rem;height:52px;}
